{
  "name": "aisports-evm-escrow-avax-fuji",
  "version": "1.0.0",
  "description": "EVM escrow contracts for USDC-based DFS contests on Avalanche Fuji testnet - Avax Build Games hackathon submission",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:flowTestnet": "hardhat run scripts/deploy.ts --network flowTestnet",
    "deploy:flowMainnet": "hardhat run scripts/deploy.ts --network flowMainnet",
    "deploy:dfs:localhost": "hardhat run scripts/deploy_dfs_escrow_manager.ts --network localhost",
    "deploy:dfs:testnet": "hardhat run scripts/deploy_dfs_escrow_manager.ts --network flowTestnet",
    "deploy:dfs:mainnet": "hardhat run scripts/deploy_dfs_escrow_manager.ts --network flowMainnet",
    "deploy:dfs:avalancheFuji": "hardhat run scripts/deploy_dfs_escrow_manager.ts --network avalancheFuji"
  },
  "keywords": [
    "solidity",
    "hardhat",
    "evm",
    "escrow",
    "dfs",
    "avalanche",
    "fuji",
    "avax",
    "usdc"
  ],
  "author": "aiSports",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^17.2.0",
    "hardhat": "^2.24.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0"
  }
}
